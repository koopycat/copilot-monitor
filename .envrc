#!/usr/bin/env bash
# direnv configuration for copilot-monitoring
# Auto-activates the devenv environment when entering this directory.

if ! has direnv; then
  echo "direnv is not installed. Install it to auto-activate the dev environment:"
  echo "  https://direnv.net/docs/installation.html"
  echo ""
  echo "Until then, run manually:"
  echo "  devenv shell"
  return 1
fi

if command -v devenv &>/dev/null; then
  eval "$(devenv shell-hook)"
else
  echo "devenv not found. Install it: https://devenv.sh/getting-started/"
  return 1
fi
