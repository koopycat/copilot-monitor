{
  "routes": [
    {
      "path": "/v1/chat/completions",
      "upstream_host": "api.kilo.ai",
      "upstream_path_prefix": "/api/gateway",
      "capture": "usage",
      "label": "kilo-chat-v1",
      "models": ["*/*"],
      "provider": "kilo"
    },
    {
      "path": "/chat/completions",
      "upstream_host": "api.kilo.ai",
      "upstream_path_prefix": "/api/gateway",
      "capture": "usage",
      "label": "kilo-chat",
      "models": ["*/*"],
      "provider": "kilo"
    },
    {
      "path": "/chat/completions",
      "upstream_host": "api.githubcopilot.com",
      "capture": "usage",
      "label": "copilot-chat",
      "provider": "copilot"
    },
    {
      "path": "/v1/engines",
      "upstream_host": "copilot-proxy.githubusercontent.com",
      "capture": "usage",
      "label": "copilot-completions",
      "prefix_match": true,
      "provider": "copilot"
    },
    {
      "path": "/v1/engines",
      "upstream_host": "copilot-proxy.githubusercontent.com",
      "capture": "usage",
      "label": "completions",
      "prefix_match": true
    },
    {
      "path": "/models",
      "upstream_host": "api.githubcopilot.com",
      "capture": "none",
      "label": "copilot-models",
      "provider": "copilot"
    },
    {
      "path": "/models",
      "upstream_host": "api.githubcopilot.com",
      "capture": "none",
      "label": "models"
    },
    {
      "path": "/chat/completions",
      "upstream_host": "api.githubcopilot.com",
      "capture": "usage",
      "label": "chat"
    },
    {
      "path": "/embeddings",
      "upstream_host": "api.githubcopilot.com",
      "capture": "usage",
      "label": "copilot-embeddings",
      "provider": "copilot"
    }
  ]
}
