{
  "routes": [
    // Local ping endpoint — responds with OK without proxying.
    {
      "label": "ping",
      "path": "/_ping",
      "upstream_host": "",
      "capture": "local"
    },
    // OpenAI chat completions — captures token usage for cost tracking.
    {
      "label": "chat",
      "path": "/v1/chat/completions",
      "upstream_host": "api.openai.com",
      "capture": "usage",
      "provider": "openai"
    },
    // Embeddings endpoint — captures request metadata only.
    {
      "label": "embeddings",
      "path": "/v1/embeddings",
      "upstream_host": "api.openai.com",
      "capture": "metadata",
      "provider": "openai"
    },
    // Models listing — no capture needed, just proxies through.
    {
      "label": "models",
      "path": "/v1/models",
      "upstream_host": "api.openai.com",
      "capture": "none",
      "provider": "openai"
    }
  ]
}
