{
  "routes": [
    // Local ping endpoint — responds with OK without proxying.
    {
      "label": "ping",
      "path": "/_ping",
      "upstream_host": "",
      "capture": "local"
    },
    // GitHub Copilot chat completions — captures token usage.
    {
      "label": "chat",
      "path": "/chat/completions",
      "upstream_host": "api.githubcopilot.com",
      "capture": "usage",
      "provider": "github"
    },
    // Agent endpoints (prefix match) — captures usage for all /agents/* paths.
    {
      "label": "agent",
      "path": "/agents",
      "upstream_host": "api.githubcopilot.com",
      "capture": "usage",
      "prefix_match": true,
      "provider": "github"
    },
    // Models listing — no capture needed.
    {
      "label": "models",
      "path": "/models",
      "upstream_host": "api.githubcopilot.com",
      "capture": "none",
      "provider": "github"
    },
    {
      "label": "models-session",
      "path": "/models/session",
      "upstream_host": "api.githubcopilot.com",
      "capture": "none",
      "provider": "github"
    },
    // Copilot responses (WebSocket) — captures usage.
    {
      "label": "responses-websocket",
      "path": "/responses",
      "upstream_host": "api.githubcopilot.com",
      "capture": "usage",
      "provider": "github"
    },
    // Embeddings — captures request metadata only.
    {
      "label": "embeddings",
      "path": "/embeddings",
      "upstream_host": "api.githubcopilot.com",
      "capture": "metadata",
      "provider": "github"
    },
    // Legacy completions engines (not billed).
    {
      "label": "completions",
      "path": "/v1/engines",
      "upstream_host": "copilot-proxy.githubusercontent.com",
      "capture": "usage",
      "prefix_match": true,
      "provider": "github",
      "not_billed": true
    },
    {
      "label": "completions",
      "path": "/v1/completions",
      "upstream_host": "copilot-proxy.githubusercontent.com",
      "capture": "usage",
      "provider": "github",
      "not_billed": true
    },
    // Copilot v1/messages (prefix match) — captures usage for all chat variants.
    {
      "label": "chat",
      "path": "/v1/messages",
      "upstream_host": "api.githubcopilot.com",
      "capture": "usage",
      "prefix_match": true,
      "provider": "github"
    }
  ]
}
